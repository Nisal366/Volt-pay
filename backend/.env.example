# Server
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Firebase Admin SDK
# Option A: recommended for local development
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Option B: deployment-friendly. Paste base64 encoded service account JSON here.
# FIREBASE_SERVICE_ACCOUNT_BASE64=

# Optional fallback if not using service account file/base64
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# Cloudinary - used for report issue image uploads and news images
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional PayHere sandbox/live values.
# The backend currently returns payment hashes and supports mock payment records.
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_CURRENCY=LKR
PAYHERE_SANDBOX=true
